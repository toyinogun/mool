# ---- App config (read by the Node app) ----

# Public URL where the recorder is reachable. Must match the Cloudflare Tunnel hostname.
PUBLIC_APP_URL=https://record.example.com

# Cloudflare R2 credentials (R2 API token scoped to the bucket).
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=mool-recordings
# Account-level R2 endpoint. Found in the Cloudflare dashboard → R2 → Manage R2 API Tokens.
R2_ENDPOINT=https://<your-account-id>.r2.cloudflarestorage.com
# Public custom domain mapped to the R2 bucket. Videos are served from here.
R2_PUBLIC_BASE_URL=https://videos.example.com

# Optional overrides
PORT=3000
DATA_DIR=/data
MAX_UPLOAD_BYTES=524288000

# ---- Cloudflare Tunnel ----

# Token issued by Cloudflare Zero Trust → Networks → Tunnels → Create Tunnel.
TUNNEL_TOKEN=your-cloudflare-tunnel-token

# --- v0.4 additions ---
# Postgres
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgres://mool:change-me@postgres:5432/mool

# Resend
RESEND_API_KEY=re_...
RESEND_FROM=auth@example.com

# Auth + view TTLs
SIGNIN_TOKEN_TTL_SECONDS=900
SESSION_TTL_SECONDS=2592000
VIEW_URL_TTL_SECONDS=3600

# Cookie
COOKIE_SECURE=true
