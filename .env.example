# ---- App ----

# Public URL where the recorder is reachable. Must match the Cloudflare Tunnel hostname.
# Required.
PUBLIC_APP_URL=https://record.example.com

# Optional. Default: 3000
PORT=3000

# Directory on the host where the app writes SQLite (legacy) data. Provided by Docker Compose.
# Optional. Default: ./data
DATA_DIR=/data

# Maximum upload size in bytes.
# Optional. Default: 524288000 (500 MB)
MAX_UPLOAD_BYTES=524288000

# ---- Cloudflare R2 ----

# R2 API token scoped to the bucket (Object Read & Write).
# Required.
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key

# Bucket name.
# Required.
R2_BUCKET=mool-recordings

# Account-level R2 endpoint. Found in Cloudflare dashboard → R2 → Manage R2 API Tokens.
# Required.
R2_ENDPOINT=https://<your-account-id>.r2.cloudflarestorage.com

# ---- Postgres ----

# Password for the `mool` Postgres user. Used by the compose postgres service.
# Required (referenced in docker-compose.yml as ${POSTGRES_PASSWORD}).
POSTGRES_PASSWORD=change-me

# Full Postgres connection URL. The `mool` user, `mool` database, `postgres` host
# (the compose service name), port 5432.
# Required.
DATABASE_URL=postgres://mool:change-me@postgres:5432/mool

# ---- Resend (magic-link email) ----

# Resend API key. Create at https://resend.com → API Keys.
# Required.
RESEND_API_KEY=re_...

# Verified sender address in Resend. Must be on a domain you have verified in Resend.
# Required.
RESEND_FROM=auth@example.com

# ---- TTLs ----

# How long a signin token (magic link) is valid, in seconds.
# Optional. Default: 900 (15 minutes)
SIGNIN_TOKEN_TTL_SECONDS=900

# How long a session cookie is valid, in seconds.
# Optional. Default: 2592000 (30 days)
SESSION_TTL_SECONDS=2592000

# How long a signed-GET viewer URL is valid, in seconds.
# Optional. Default: 3600 (1 hour)
VIEW_URL_TTL_SECONDS=3600

# ---- Cookie ----

# Set to false for local HTTP development (Secure cookies require HTTPS).
# Optional. Default: true
COOKIE_SECURE=true

# ---- Cloudflare Tunnel ----

# Token issued by Cloudflare Zero Trust → Networks → Tunnels → Create Tunnel.
# Required by the cloudflared compose service.
TUNNEL_TOKEN=your-cloudflare-tunnel-token
