{
  "name": "mool-app",
  "version": "0.1.0",
  "private": true,
  "description": "Mool v0.1 — anonymous screen recorder",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "cookie-parser": "^1.4.7",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.0",
    "pg": "^8.20.0",
    "resend": "^6.12.3",
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.2",
    "drizzle-kit": "^0.31.10",
    "supertest": "^7.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
